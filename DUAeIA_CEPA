    <!-- Script de interactividad -->
    <script>
        const tabsId = ['paso1', 'paso2', 'paso3', 'paso4', 'paso5'];

        function openTab(index) {
            // Ocultar todos los contenidos
            const tabContents = document.getElementsByClassName("tab-content");
            for (let i = 0; i < tabContents.length; i++) {
                tabContents[i].style.display = "none";
            }

            // Eliminar estilos activos de las pestañas superiores
            const tabLinks = document.getElementsByClassName("tab-btn");
            for (let i = 0; i < tabLinks.length; i++) {
                tabLinks[i].className = tabLinks[i].className.replace(" border-secundario text-secundario", " border-transparent text-[#8C7A6B] hover:text-primario hover:bg-[#F0EBE1]");
            }

            // Mostrar el paso actual
            document.getElementById(tabsId[index]).style.display = "block";
            tabLinks[index].className = tabLinks[index].className.replace(" border-transparent text-[#8C7A6B] hover:text-primario hover:bg-[#F0EBE1]", " border-secundario text-secundario");
        }

        // Función auxiliar para navegar desde los botones inferiores y hacer scroll automático
        function goToTab(index) {
            openTab(index);
            document.getElementById("nav-container").scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        // Abrir pestaña por defecto al cargar
        document.addEventListener("DOMContentLoaded", function() {
            openTab(0);
        });
    </script>
