        /* Paleta Otoño Cálido y color corporativo para desplegables */
        :root {
            --color-marron-oscuro: #4A3021;
            --color-terracota: #B95337;
            --color-ocre: #D68C3A;
            --color-arena: #F7EFE8;
            --color-texto: #3E332C;
            --color-desplegables: rgb(170, 0, 77);
        }

        body {
            font-family: 'Open Sans', sans-serif;
            background-color: var(--color-arena);
            color: var(--color-texto);
            /* Tamaño base de fuente aumentado para accesibilidad */
            font-size: 110%; 
        }

        /* Aplicar Montserrat a los encabezados */
        h1, h2, h3, h4, h5, .font-montserrat, summary {
            font-family: 'Montserrat', sans-serif;
        }

        /* Clases de utilidad para colores */
        .bg-primario { background-color: var(--color-marron-oscuro); }
        .text-primario { color: var(--color-marron-oscuro); }
        
        .bg-secundario { background-color: var(--color-terracota); }
        .text-secundario { color: var(--color-terracota); }
        .border-secundario { border-color: var(--color-terracota); }

        .bg-acento { background-color: var(--color-ocre); }
        .text-acento { color: var(--color-ocre); }

        .bg-desplegables { background-color: var(--color-desplegables); }
        .text-desplegables { color: var(--color-desplegables); }

        /* Ocultar contenido de pestañas por defecto */
        .tab-content {
            display: none;
            animation: fadeIn 0.4s ease-in-out;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        /* Pulsación de botón grabar */
        .pulse-rojo {
            animation: pulse-red 2s infinite;
        }
        @keyframes pulse-red {
            0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.7); }
            70% { transform: scale(1); box-shadow: 0 0 0 12px rgba(220, 38, 38, 0); }
            100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(220, 38, 38, 0); }
        }

        /* Ocultar barra de desplazamiento en las pestañas */
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
